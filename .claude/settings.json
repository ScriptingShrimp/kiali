{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(make -qp)",
      "Bash(make test:*)",
      "Bash(make build:*)",
      "Bash(make format)",
      "Bash(make lint)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl describe:*)",
      "Read(**/AGENTS.md)",
      "Read(**/.claude/**)"
    ]
  }
}
